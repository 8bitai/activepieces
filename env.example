# =============================================================================
# Activepieces Environment Variables - Example / Template
# =============================================================================
# Copy this file, fill in the real values, and pass to DevOps securely.
# DO NOT commit the filled-in version to git.
#
# Generate secrets with:
#   openssl rand -hex 32   → for AP_JWT_SECRET
#   openssl rand -hex 16   → for AP_ENCRYPTION_KEY
# =============================================================================


# -----------------------------------------------------------------------------
# App / URLs  (REQUIRED)
# -----------------------------------------------------------------------------

# The publicly reachable URL of your Activepieces instance.
# This is critical — webhooks sent to external services use this URL.
# Example: https://activepieces.yourcompany.com
AP_FRONTEND_URL=https://your-domain.com

# Internal webhook URL (usually same as AP_FRONTEND_URL in production)
AP_WEBHOOK_URL=https://your-domain.com

AP_ENVIRONMENT=prod


# -----------------------------------------------------------------------------
# Security  (REQUIRED — generate fresh values, never reuse)
# -----------------------------------------------------------------------------

# Generate: openssl rand -hex 32
AP_JWT_SECRET=<generate-with-openssl-rand-hex-32>

# Generate: openssl rand -hex 16
AP_ENCRYPTION_KEY=<generate-with-openssl-rand-hex-16>

# API key for internal service-to-service calls
AP_API_KEY=<generate-with-openssl-rand-hex-32>


# -----------------------------------------------------------------------------
# Database (PostgreSQL)  (REQUIRED)
# -----------------------------------------------------------------------------

AP_DB_TYPE=POSTGRES
AP_POSTGRES_HOST=<your-postgres-host>
AP_POSTGRES_PORT=5432
AP_POSTGRES_DATABASE=activepieces
AP_POSTGRES_USERNAME=<your-postgres-username>
AP_POSTGRES_PASSWORD=<your-postgres-password>
AP_POSTGRES_USE_SSL=false
# AP_POSTGRES_SSL_CA=<path-to-ca-cert>  # Uncomment if SSL is required


# -----------------------------------------------------------------------------
# Cache (Redis)  (REQUIRED)
# -----------------------------------------------------------------------------

AP_QUEUE_MODE=REDIS
AP_REDIS_HOST=<your-redis-host>
AP_REDIS_PORT=6379
# AP_REDIS_PASSWORD=<your-redis-password>  # Uncomment if Redis has auth


# -----------------------------------------------------------------------------
# Worker / Execution
# -----------------------------------------------------------------------------

AP_WORKER_CONCURRENCY=5
AP_FLOW_WORKER_CONCURRENCY=5
AP_SCHEDULED_WORKER_CONCURRENCY=5
AP_SANDBOX_MEMORY_LIMIT=524288
AP_FLOW_TIMEOUT_SECONDS=600
AP_WEBHOOK_TIMEOUT_SECONDS=30
AP_TRIGGER_DEFAULT_POLL_INTERVAL=5

# For split deployment (Frontend+Backend pods):
# Set in backend pod only — leave unset for combined mode
# AP_CONTAINER_TYPE=WORKER_AND_APP


# -----------------------------------------------------------------------------
# Pieces / Integrations
# -----------------------------------------------------------------------------

AP_PIECES_SOURCE=CLOUD_AND_DB
AP_PIECES_SYNC_MODE=OFFICIAL_AUTO


# -----------------------------------------------------------------------------
# Features
# -----------------------------------------------------------------------------

AP_TELEMETRY_ENABLED=false
AP_CHATBOT_ENABLED=false

# Neutrino Gateway (only if you use embed auth)
# AP_EMBED_AUTH_VIA_NEUTRINO_GATEWAY=true
# AP_NEUTRINO_GATEWAY_URL=https://your-neutrino-gateway


# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------

AP_LOG_LEVEL=info
AP_LOG_PRETTY=false
AP_ENRICH_ERROR_CONTEXT=true


# -----------------------------------------------------------------------------
# Storage paths (inside the container — usually no need to change)
# -----------------------------------------------------------------------------

AP_CACHE_PATH=/usr/src/app/cache
AP_CONFIG_PATH=/usr/src/app/config
