          "skip": false,
          "type": "CODE",
          "valid": true,
          "displayName": "Call MCP",
          "settings": {
            "input": {
              "role": "{{trigger.role}}"
            },
            "sampleData": {},
            "sourceCode": {
              "code": "export const code = async (inputs) => {\n  const args = { per_page: 25 };\n  if (inputs.role) args.role = inputs.role;\n  const response = await fetch('https://arlena-purplish-chuck.ngrok-free.dev/mcp', {\n    method: 'POST',\n    headers: {\n      'Content-Type': 'application/json',\n      'Accept': 'application/json',\n      'ngrok-skip-browser-warning': 'true'\n    },\n    body: JSON.stringify({\n      jsonrpc: '2.0',\n      id: 1,\n      method: 'tools/call',\n      params: { name: 'zendesk_get_users', arguments: args }\n    })\n  });\n  const data = await response.json();\n  return data.result || data;\n};",
              "packageJson": "{}"
            },
            "errorHandlingOptions": {
              "retryOnFailure": {
                "value": false
              },
              "continueOnFailure": {
                "value": false
              }
            }
          },
