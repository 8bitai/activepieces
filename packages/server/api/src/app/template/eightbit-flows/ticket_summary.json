              "pieceVersion": "0.1.5",
              "sampleData": {},
              "input": {
                "model": "azure/gpt-4.1",
                "prompt": "You are a customer support assistant. A support agent needs a quick summary of this Zendesk ticket.\n\nTicket Data: {{Fetch_Ticket.result}}\n\nProvide exactly:\n1. Issue Summary (2-3 sentences \u2014 what is the customer's problem?)\n2. Current Status (one line)\n3. Recommended Next Action (one clear sentence)\n\nBe concise and actionable.",
                "provider": "activepieces",
