  },
  "flows": [
    {
      "displayName": "zendesk_update_ticket",
      "trigger": {
        "name": "trigger",
        "valid": true,
        "displayName": "Callable Flow",
        "type": "PIECE_TRIGGER",
        "settings": {
          "pieceName": "@activepieces/piece-subflows",
          "pieceVersion": "0.4.10",
          "triggerName": "callableFlow",
          "sampleData": {},
          "input": {
            "mode": "advanced",
            "exampleData": {
              "sampleData": {
                "type": "object",
                "required": [
                  "ticket_id"
                ],
                "properties": {
                  "ticket_id": {
                    "type": "string",
                    "description": "ID of the ticket to update"
                  },
                  "status": {
                    "type": "string",
                    "description": "New status: open, pending, solved, closed"
                  },
                  "priority": {
                    "type": "string",
                    "description": "New priority: low, normal, high, urgent"
                  },
                  "comment": {
                    "type": "string",
                    "description": "Internal note or reply to add to the ticket"
                  }
                }
              }
            }
          },
          "propertySettings": {
            "mode": {
              "type": "MANUAL"
            },
            "exampleData": {
              "type": "MANUAL",
              "schema": {
                "sampleData": {
                  "type": "JSON",
                  "required": true,
                  "displayName": "Sample Data"
                }
              }
            }
          }
        },
        "nextAction": {
          "name": "step_1",
          "skip": false,
          "type": "CODE",
          "valid": true,
          "displayName": "Call MCP",
          "settings": {
            "input": {
              "ticket_id": "{{trigger.ticket_id}}",
              "status": "{{trigger.status}}",
              "priority": "{{trigger.priority}}",
              "comment": "{{trigger.comment}}"
            },
            "sampleData": {},
            "sourceCode": {
              "code": "export const code = async (inputs) => {\n  const args = { ticket_id: inputs.ticket_id };\n  if (inputs.status)   args.status   = inputs.status;\n  if (inputs.priority) args.priority = inputs.priority;\n  if (inputs.comment)  args.comment  = inputs.comment;\n  const response = await fetch('https://arlena-purplish-chuck.ngrok-free.dev/mcp', {\n    method: 'POST',\n    headers: {\n      'Content-Type': 'application/json',\n      'Accept': 'application/json',\n      'ngrok-skip-browser-warning': 'true'\n    },\n    body: JSON.stringify({\n      jsonrpc: '2.0',\n      id: 1,\n      method: 'tools/call',\n      params: { name: 'zendesk_update_ticket', arguments: args }\n    })\n  });\n  const data = await response.json();\n  return data.result || data;\n};",
              "packageJson": "{}"
            },
            "errorHandlingOptions": {
              "retryOnFailure": {
                "value": false
              },
              "continueOnFailure": {
                "value": false
              }
            }
          },
          "nextAction": {
            "name": "step_return",
