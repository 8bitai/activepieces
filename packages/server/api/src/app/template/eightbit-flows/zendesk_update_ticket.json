{
  "name": "Zendesk Update Ticket",
  "type": "SHARED",
  "summary": "Update a Zendesk ticket's status, priority, or add a comment.",
  "description": "A callable workflow that accepts a ticket ID along with optional fields (status, priority, comment) and calls the MCP zendesk_update_ticket tool to apply the update. Returns a confirmation with the updated ticket result.",
