var addOrRemoveTagOnConversationAction = createAction2({
  auth: intercomAuth,
  name: "add-or-remove-tag-on-conversation",
  displayName: "Add/Remove Tag on Conversation",
  description: "Attach or remove a tag from a specific conversation.",
  props: {
    conversationId: conversationIdProp("Conversation ID", true),
    tagId: tagIdProp("Tag", true),
    untag: Property.Checkbox({
      displayName: "Untag ?",
      required: false,
      defaultValue: false
    })
  },
  async run(context5) {
    const client = intercomClient(context5.auth);
    const admin = await client.admins.identify();
    const adminId = admin.id;
    if (context5.propsValue.untag) {
      const response2 = await client.tags.untagConversation({
        conversation_id: context5.propsValue.conversationId,
        tag_id: context5.propsValue.tagId,
        admin_id: adminId
      });
      return response2;
    }
    const response = await client.tags.tagConversation({
      conversation_id: context5.propsValue.conversationId,
      id: context5.propsValue.tagId,
      admin_id: adminId
    });
    return response;
  }
});

// packages/pieces/community/intercom/src/lib/actions/add-remove-tag-on-company.ts
var addOrRemoveTagOnCompanyAction = createAction2({
  auth: intercomAuth,
  name: "add-or-remove-tag-on-company",
  displayName: "Add/Remove Tag on Company",
  description: "Attach or remove a tag from a specific company.",
  props: {
    companyId: companyIdProp("Company ID", true),
    tagName: Property.ShortText({
      displayName: "Tag Name",
      required: true
    }),
    untag: Property.Checkbox({
      displayName: "Untag ?",
      required: false,
      defaultValue: false
    })
  },
  async run(context5) {
    const client = intercomClient(context5.auth);
    if (context5.propsValue.untag) {
      const company = await client.companies.find({ company_id: context5.propsValue.companyId });
      const userDefinedCompanyId = company.company_id;
      const response2 = await client.tags.create({
        name: context5.propsValue.tagName,
        companies: [
          { id: context5.propsValue.companyId, untag: true, company_id: userDefinedCompanyId }
        ]
      });
      return response2;
    }
    const response = await client.tags.create({
      name: context5.propsValue.tagName,
      companies: [{ id: context5.propsValue.companyId }]
    });
    return response;
  }
});

