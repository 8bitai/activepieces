  config: {
    security: securityAccess.public()
  },
  schema: {
    params: import_typebox150.Type.Object({
      licenseKey: import_typebox150.Type.String()
    })
  }
};

// packages/server/api/src/app/ee/license-keys/license-keys-module.ts
var licenseKeysModule = async (app2) => {
  systemJobHandlers.registerJobHandler("trial-tracker" /* TRIAL_TRACKER */, async () => {
    const platforms = await platformService.getAll();
    for (const platform of platforms) {
      const platformWithPlan = await platformService.getOneWithPlan(platform.id);
      if (isNil(platformWithPlan)) {
        continue;
      }
      if (isNil(platformWithPlan.plan.licenseKey) || isEmpty(platformWithPlan.plan.licenseKey)) {
        continue;
      }
      try {
        const key = await licenseKeysService(app2.log).verifyKeyOrReturnNull({
          platformId: platformWithPlan.id,
          license: platformWithPlan.plan.licenseKey
        });
        if (isNil(key)) {
          await licenseKeysService(app2.log).downgradeToFreePlan(platformWithPlan.id);
          continue;
        }
        await licenseKeysService(app2.log).applyLimits(platformWithPlan.id, key);
      } catch (e) {
        exceptionHandler.handle(e, app2.log);
      }
    }
  });
  await systemJobsSchedule(app2.log).upsertJob({
    job: {
      name: "trial-tracker" /* TRIAL_TRACKER */,
      data: {}
    },
    schedule: {
      type: "repeated",
      cron: "*/59 23 * * *"
    }
  });
  await app2.register(licenseKeysController, { prefix: "/v1/license-keys" });
};

