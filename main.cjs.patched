var ticketTypeIdProp = (displayName, required = true) => Property.Dropdown({
  auth: intercomAuth,
  displayName,
  required,
  refreshers: [],
  options: async ({ auth }) => {
    if (!auth) {
      return {
        options: [],
        disabled: true,
        placeholder: "Please connect your account first."
      };
    }
    const authValue = auth;
    const response = await httpClient.sendRequest({
      method: "GET" /* GET */,
      url: `https://api.${authValue.props?.["region"]}.io/ticket_types `,
      authentication: {
        type: "BEARER_TOKEN" /* BEARER_TOKEN */,
        token: authValue.access_token
      }
    });
    const options = [];
    for (const type of response.body.data) {
      options.push({
        value: type.id,
        label: type.name
      });
    }
    return {
      disabled: false,
      options
    };
  }
});
var ticketIdProp = (displayName, required = true) => Property.Dropdown({
  auth: intercomAuth,
  displayName,
  required,
  refreshers: ["ticketTypeId"],
  options: async ({ auth, ticketTypeId }) => {
    if (!auth || !ticketTypeId) {
      return {
        options: [],
        disabled: true,
        placeholder: "Please connect your account first."
      };
    }
    const authValue = auth;
    const client = intercomClient(authValue);
    const options = [];
    const response = await client.tickets.search({
      query: {
        field: "ticket_type_id",
        operator: "=",
        value: ticketTypeId
      },
      pagination: { per_page: 100 }
    });
    for await (const ticket of response) {
      options.push({
        value: ticket.id,
        label: ticket.ticket_attributes["_default_title_"] ?? ticket.id
      });
    }
    return {
      disabled: false,
      options
    };
  }
});
var ticketPropertiesProp = (displayName, required = true) => Property.DynamicProperties({
  auth: intercomAuth,
  displayName,
  refreshers: ["ticketTypeId"],
  required,
  props: async ({ auth, ticketTypeId }) => {
    if (!auth) return {};
    if (!ticketTypeId) return {};
    const props = {};
    const authValue = auth;
    const response = await httpClient.sendRequest({
      method: "GET" /* GET */,
      url: `https://api.${authValue.props?.["region"]}.io/ticket_types/${ticketTypeId} `,
      authentication: {
        type: "BEARER_TOKEN" /* BEARER_TOKEN */,
        token: authValue.access_token
      }
    });
    for (const field of response.body.ticket_type_attributes.data) {
      switch (field.data_type) {
        case "string":
          props[field.name] = Property.LongText({
            displayName: field.name === "_default_title_" ? "Title (Default)" : field.name === "_default_description_" ? "Description (Default)" : field.name,
            required: false
          });
          break;
        case "integer":
        case "decimal":
          props[field.name] = Property.Number({
            displayName: field.name,
            required: false
          });
          break;
        case "boolean":
          props[field.name] = Property.Checkbox({
            displayName: field.name,
            required: false
          });
          break;
        case "datetime":
          props[field.name] = Property.DateTime({
            displayName: field.name,
            required: false
          });
          break;
        case "list":
          {
            const options = field.input_options.list_options;
            props[field.name] = Property.StaticDropdown({
              displayName: field.name,
              required: false,
              options: {
                disabled: false,
                options: options ? options.map((option) => ({
                  value: option.id,
                  label: option.label
                })) : []
              }
            });
          }
          break;
        default:
          break;
      }
    }
    return props;
  }
});

