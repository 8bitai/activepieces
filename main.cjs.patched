    /^video\/.*/,
    { parseAs: "buffer" },
    async (_request, payload) => {
      return payload;
    }
  );
  app2.addContentTypeParser(
    /^audio\/.*/,
    { parseAs: "buffer" },
    async (_request, payload) => {
      return payload;
    }
  );
  app2.addContentTypeParser(
    "application/pdf",
    { parseAs: "buffer" },
    async (_request, payload) => {
      return payload;
    }
  );
  app2.addContentTypeParser(
    "application/zip",
    { parseAs: "buffer" },
    async (_request, payload) => {
      return payload;
    }
  );
  app2.addContentTypeParser(
    "application/gzip",
    { parseAs: "buffer" },
    async (_request, payload) => {
      return payload;
    }
  );
  await app2.register(import_fastify_xml_body_parser.default);
  await app2.register(webhookController, { prefix: "/v1/webhooks" });
};

