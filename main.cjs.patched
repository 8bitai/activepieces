var squareAuth = PieceAuth.OAuth2({
  description: "Authentication",
  authUrl: "https://connect.squareup.com/oauth2/authorize",
  tokenUrl: "https://connect.squareup.com/oauth2/token",
  required: true,
  scope: [
    "MERCHANT_PROFILE_READ",
    "CUSTOMERS_READ",
    "CUSTOMERS_WRITE",
    "ITEMS_READ",
    "ITEMS_WRITE",
    "ORDERS_READ",
    "ORDERS_WRITE",
    "PAYMENTS_READ",
    "INVOICES_READ",
    "APPOINTMENTS_READ",
    "APPOINTMENTS_WRITE"
  ]
});
var square = createPiece({
  displayName: "Square",
  description: "Payment solutions for every business",
  minimumSupportedRelease: "0.30.0",
  logoUrl: "https://cdn.activepieces.com/pieces/square.png",
  categories: ["COMMERCE" /* COMMERCE */],
  authors: ["kishanprmr", "MoShizzle", "khaledmashaly", "abuaboud"],
  auth: squareAuth,
  events: {
    verify: ({ webhookSecret, payload, appWebhookUrl }) => {
      const signature = payload.headers["x-square-hmacsha256-signature"];
      const hmac = import_crypto4.default.createHmac("sha256", webhookSecret);
      hmac.update(appWebhookUrl + payload.rawBody);
      const hash = hmac.digest("base64");
      return hash === signature;
    },
    parseAndReply: ({ payload }) => {
      const payloadBody = payload.body;
      return {
        event: payloadBody?.type,
        identifierValue: payloadBody?.merchant_id
      };
    }
  },
  actions: [],
  triggers
});

// packages/server/api/src/app/trigger/app-event-routing/app-event-routing.module.ts
var import_http_status_codes50 = require("http-status-codes");
var appWebhooks = {
  slack,
  square,
  "facebook-leads": facebookLeads,
  intercom
};
var pieceNames = {
  slack: "@activepieces/piece-slack",
  square: "@activepieces/piece-square",
  "facebook-leads": "@activepieces/piece-facebook-leads",
  intercom: "@activepieces/piece-intercom"
};
var appEventRoutingModule = async (app2) => {
  await app2.register(appEventRoutingController, { prefix: "/v1/app-events" });
};
var appEventRoutingController = async (fastify2) => {
  fastify2.all(
    "/:pieceUrl",
    {
      config: {
        rawBody: true,
        security: securityAccess.public()
      }
    },
    async (request, requestReply) => {
      const pieceUrl = request.params.pieceUrl;
      const payload = {
        headers: request.headers,
        body: request.body,
        rawBody: request.rawBody,
        method: request.method,
        queryParams: request.query
      };
      const piece = appWebhooks[pieceUrl];
      if (isNil(piece)) {
        throw new ActivepiecesError({
          code: "PIECE_NOT_FOUND" /* PIECE_NOT_FOUND */,
          params: {
            pieceName: pieceUrl,
            pieceVersion: "latest",
            message: "Pieces is not found in app event routing"
          }
        });
      }
      const appName = pieceNames[pieceUrl];
      assertNotNullOrUndefined(piece.events, "Event is possible in this piece");
      const { reply, event, identifierValue } = piece.events.parseAndReply({
        payload,
        server: {
          publicUrl: await domainHelper.getPublicUrl({ path: "" })
        }
      });
      if (!isNil(reply)) {
        request.log.info(
          {
            reply,
            piece: pieceUrl
          },
          "[AppEventRoutingController#event] reply"
        );
        return requestReply.status(import_http_status_codes50.StatusCodes.OK).headers(reply?.headers ?? {}).send(reply?.body ?? {});
      }
      request.log.info(
        {
          event,
          identifierValue
        },
        "[AppEventRoutingController#event] event"
      );
      if (isNil(event) || isNil(identifierValue)) {
        return requestReply.status(import_http_status_codes50.StatusCodes.BAD_REQUEST).send({});
      }
      const listeners4 = await appEventRoutingService.listListeners({
        appName,
        event,
        identifierValue
      });
      const eventsQueue = listeners4.map(async (listener2) => {
        const requestId = apId();
        const flow = await flowService(request.log).getOne({ id: listener2.flowId, projectId: listener2.projectId });
        if (isNil(flow)) {
          return;
        }
        const flowVersionIdToRun = await webhookHandler.getFlowVersionIdToRun("locked_fall_back_to_latest" /* LOCKED_FALL_BACK_TO_LATEST */, flow);
        const platformId = await projectService.getPlatformId(listener2.projectId);
        return jobQueue(request.log).add({
          id: requestId,
          type: "one_time" /* ONE_TIME */,
          data: {
            platformId,
            projectId: listener2.projectId,
            schemaVersion: LATEST_JOB_DATA_SCHEMA_VERSION,
            requestId,
            payload,
            flowId: listener2.flowId,
            jobType: "EXECUTE_WEBHOOK" /* EXECUTE_WEBHOOK */,
            runEnvironment: "PRODUCTION" /* PRODUCTION */,
            saveSampleData: await triggerSourceService(request.log).existsByFlowId({
              flowId: listener2.flowId,
              simulate: true
            }),
            flowVersionIdToRun,
            execute: flow.status === "ENABLED" /* ENABLED */
          }
        });
      });
      rejectedPromiseHandler(Promise.all(eventsQueue), request.log);
      return requestReply.status(import_http_status_codes50.StatusCodes.OK).send({});
    }
  );
};

// packages/server/api/src/app/trigger/test-trigger/test-trigger-service.ts
var lockKey = (flowId) => `${flowId}-test-trigger`;
var testTriggerService = (log95) => {
  return {
    async test(params) {
      const { testStrategy, ...executeParams } = params;
      log95.info("[testTriggerService#test] Starting test trigger");
      return distributedLock(log95).runExclusive({
        key: lockKey(executeParams.flowId),
        timeoutInSeconds: 120,
        fn: async () => {
          log95.info("[testTriggerService#test] Acquired lock");
          const populatedFlow = await flowService(log95).getOnePopulatedOrThrow({
            id: executeParams.flowId,
            projectId: executeParams.projectId,
            versionId: executeParams.flowVersionId
          });
          switch (testStrategy) {
            case "SIMULATION" /* SIMULATION */: {
              const exists = await triggerSourceService(log95).existsByFlowId({
                flowId: executeParams.flowId,
                simulate: true
              });
              log95.info({
                exists
              }, "[testTriggerService#test] Trigger source exists");
              if (exists) {
                await triggerSourceService(log95).disable({
                  flowId: executeParams.flowId,
                  projectId: executeParams.projectId,
                  simulate: true,
                  ignoreError: true
                });
                return;
              }
              await triggerSourceService(log95).enable({
                flowVersion: populatedFlow.version,
                projectId: executeParams.projectId,
                simulate: true
              });
              return;
            }
            case "TEST_FUNCTION" /* TEST_FUNCTION */: {
