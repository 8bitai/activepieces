function isHandshakeRequest(params) {
  const { payload, handshakeConfiguration } = params;
  if (isNil(handshakeConfiguration) || isNil(handshakeConfiguration.strategy) || isNil(handshakeConfiguration.paramName)) {
    return false;
  }
  const { strategy, paramName } = handshakeConfiguration;
  switch (strategy) {
    case "HEADER_PRESENT" /* HEADER_PRESENT */:
      return paramName.toLowerCase() in payload.headers;
    case "QUERY_PRESENT" /* QUERY_PRESENT */:
      return paramName in payload.queryParams;
    case "BODY_PARAM_PRESENT" /* BODY_PARAM_PRESENT */:
      return typeof payload.body === "object" && payload.body !== null && paramName in payload.body;
    default:
      return false;
  }
}

// packages/server/api/src/app/flows/flow/flow-execution-cache.ts
