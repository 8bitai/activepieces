            id: table.id,
            projectId
          });
          break;
        }
      }
    }
    for (const operation of flows) {
      switch (operation.type) {
        case "UPDATE_FLOW" /* UPDATE_FLOW */: {
          const flowUpdated = await projectStateHelper(log95).updateFlowInProject(operation.flowState, operation.newFlowState, projectId);
          const keepOriginalState = projectStateHelper(log95).republishFlow({ flow: flowUpdated, projectId, status: operation.flowState.status });
          publishJobs.push(keepOriginalState);
          break;
        }
        case "CREATE_FLOW" /* CREATE_FLOW */: {
          const flowCreated = await projectStateHelper(log95).createFlowInProject(operation.flowState, projectId);
          const alwaysEnableNewFlow = projectStateHelper(log95).republishFlow({ flow: flowCreated, projectId, status: "ENABLED" /* ENABLED */ });
          publishJobs.push(alwaysEnableNewFlow);
          break;
        }
        case "DELETE_FLOW" /* DELETE_FLOW */: {
          await projectStateHelper(log95).deleteFlowFromProject(operation.flowState.id, projectId);
          break;
        }
      }
    }
  },
  async save(projectId, name, log96) {
    const fileToSave = await this.getProjectState(projectId, log96);
    const fileData = Buffer.from(JSON.stringify(fileToSave));
