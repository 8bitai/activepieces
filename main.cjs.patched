      });
      const client = new import_web_api3.WebClient(token2);
      await client.chat.update({
        ts: messageTs,
        channel: dmId,
        text: context5.propsValue.text,
        blocks: [
          {
            type: "section",
            text: {
              type: "mrkdwn",
              text: `${context5.propsValue.text}`
            }
          },
          {
            type: "actions",
            block_id: "actions",
            elements: [
              {
                type: "button",
                text: {
                  type: "plain_text",
                  text: "Approve"
                },
                style: "primary",
                url: approvalLink
              },
              {
                type: "button",
                text: {
                  type: "plain_text",
                  text: "Disapprove"
                },
                style: "danger",
                url: disapprovalLink
              }
            ]
          }
        ]
      });
      context5.run.pause({
        pauseMetadata: {
          type: "WEBHOOK" /* WEBHOOK */,
          response: {}
        }
      });
      return {
        approved: false,
        // default approval is false
        messageTs
      };
    } else {
