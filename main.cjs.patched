// packages/server/api/src/app/ee/platform/platform-plan/stripe-billing.controller.ts
var import_http_status_codes20 = require("http-status-codes");
var stripeBillingController = async (fastify2) => {
  fastify2.post(
    "/stripe/webhook",
    WebhookRequest,
    async (request, reply) => {
      try {
        const payload = request.rawBody;
        const signature = request.headers["stripe-signature"];
        const stripe = stripeHelper(request.log).getStripe();
        if (isNil(stripe)) {
          return await reply.status(import_http_status_codes20.StatusCodes.OK).send({ received: true });
        }
        const webhookSecret = system.getOrThrow("STRIPE_WEBHOOK_SECRET" /* STRIPE_WEBHOOK_SECRET */);
        const webhook = stripe.webhooks.constructEvent(
          payload,
          signature,
          webhookSecret
        );
        switch (webhook.type) {
          case "checkout.session.completed": {
            const session = webhook.data.object;
            if (isNil(session.metadata)) {
              break;
            }
            if (session.metadata.type === "ai-credit-payment" /* AI_CREDIT_PAYMENT */) {
              const platformId = session.metadata.platformId;
              const intent = await stripe.paymentIntents.retrieve(
                session.payment_intent
              );
              const amountInCents = intent.amount;
              const amountInUsd = amountInCents / 100;
              await platformAiCreditsService(request.log).aiCreditsPaymentSucceeded(platformId, amountInUsd, "ai-credit-payment" /* AI_CREDIT_PAYMENT */);
            }
            if (session.metadata.type === "ai-credit-auto-top-up" /* AI_CREDIT_AUTO_TOP_UP */) {
              const setupIntent = await stripe.setupIntents.retrieve(
                session.setup_intent
              );
              const paymentMethodId = setupIntent.payment_method;
              const platformId = session.metadata.platformId;
              await platformAiCreditsService(request.log).handleAutoTopUpCheckoutSessionCompleted(platformId, paymentMethodId);
            }
            break;
          }
          case "invoice.paid": {
            const invoice = webhook.data.object;
            if (isNil(invoice.metadata)) {
              break;
            }
            if (invoice.metadata.type === "ai-credit-auto-top-up" /* AI_CREDIT_AUTO_TOP_UP */) {
              const platformId = invoice.metadata.platformId;
              const amountInCents = invoice.amount_paid;
              const amountInUsd = amountInCents / 100;
              await platformAiCreditsService(request.log).aiCreditsPaymentSucceeded(platformId, amountInUsd, "ai-credit-auto-top-up" /* AI_CREDIT_AUTO_TOP_UP */);
            }
            break;
          }
          case "customer.subscription.deleted":
          case "customer.subscription.created":
          case "customer.subscription.updated": {
            const subscription = webhook.data.object;
            const platformId = subscription.metadata.platformId;
            const { startDate, endDate, cancelDate } = await stripeHelper(request.log).getSubscriptionCycleDates(subscription);
            const extraActiveFlows = subscription.items.data.find((item) => ACTIVE_FLOW_PRICE_ID === item.price.id)?.quantity ?? 0;
            const newLimits = { ...STANDARD_CLOUD_PLAN };
            const subscriptionEnded = webhook.type === "customer.subscription.deleted";
            if (subscriptionEnded) {
              await platformPlanService(request.log).update({
                ...newLimits,
                platformId,
                plan: "standard" /* STANDARD */,
                stripeSubscriptionStatus: "canceled" /* CANCELED */,
                stripeSubscriptionId: void 0,
                stripeSubscriptionStartDate: void 0,
                stripeSubscriptionEndDate: void 0,
                stripeSubscriptionCancelDate: void 0
              });
              break;
            }
            if (extraActiveFlows > 0) {
              newLimits.activeFlowsLimit = (newLimits.activeFlowsLimit ?? 0) + extraActiveFlows;
            }
            await platformPlanService(request.log).update({
              ...newLimits,
              platformId,
              plan: "standard" /* STANDARD */,
              stripeSubscriptionId: subscription.id,
              stripeSubscriptionStatus: subscription.status,
              stripeSubscriptionStartDate: startDate,
              stripeSubscriptionEndDate: endDate,
              stripeSubscriptionCancelDate: cancelDate
            });
            break;
          }
          default:
            request.log.info(`Unhandled webhook event type: ${webhook.type}`);
            break;
        }
        return await reply.status(import_http_status_codes20.StatusCodes.OK).send({ received: true });
      } catch (err) {
        request.log.error(err);
        request.log.warn("\u26A0\uFE0F  Webhook signature verification failed.");
        exceptionHandler.handle(err, request.log);
        return reply.status(import_http_status_codes20.StatusCodes.BAD_REQUEST).send("Invalid webhook signature");
      }
    }
  );
};
var WebhookRequest = {
  config: {
    security: securityAccess.public(),
    rawBody: true
  }
};

