// packages/pieces/community/facebook-leads/src/lib/common/index.ts
var facebookLeadsCommon = {
  baseUrl: "https://graph.facebook.com",
  page: Property.Dropdown({
    auth: facebookLeadsAuth,
    displayName: "Page",
    required: true,
    refreshers: [],
    options: async ({ auth }) => {
      if (!auth) {
        return {
          disabled: true,
          options: [],
          placeholder: "Connect your account first."
        };
      }
      try {
        const authValue = auth;
        const options = [];
        let nextUrl = `${facebookLeadsCommon.baseUrl}/me/accounts`;
        do {
          const response = await httpClient.sendRequest({
            method: "GET" /* GET */,
            url: nextUrl,
            queryParams: {
              access_token: authValue.access_token
            }
          });
          const { data, paging } = response.body;
          const items = data ?? [];
          for (const page of items) {
            options.push({
              label: page.name,
              value: {
                id: page.id,
                accessToken: page.access_token
              }
            });
          }
          nextUrl = paging?.next ?? null;
        } while (nextUrl);
        return {
          disabled: false,
          options
        };
      } catch (e) {
        return {
          disabled: true,
          options: [],
          placeholder: "Error occured while fetching pages."
        };
      }
    }
  }),
  form: Property.Dropdown({
    auth: facebookLeadsAuth,
    displayName: "Form",
    required: false,
    refreshers: ["page"],
    options: async ({ page }) => {
      if (!page) {
        return {
          disabled: true,
          options: [],
          placeholder: "Select page first."
        };
      }
      try {
        const pageDeatils = page;
        const options = [
          {
            label: "All Forms (Default)",
            value: "all"
          }
        ];
        let nextUrl = `${facebookLeadsCommon.baseUrl}/${pageDeatils.id}/leadgen_forms`;
        do {
          const response = await httpClient.sendRequest({
            method: "GET" /* GET */,
            url: nextUrl,
            queryParams: {
              access_token: pageDeatils.accessToken
            }
          });
          const { data, paging } = response.body;
          const items = data ?? [];
          for (const form of items) {
            options.push({
              label: form.name,
              value: form.id
            });
          }
          nextUrl = paging?.next ?? null;
        } while (nextUrl);
        return {
          disabled: false,
          options
        };
      } catch (e) {
        return {
          disabled: true,
          options: [],
          placeholder: "Error occured while fetching forms."
        };
      }
    }
  }),
  subscribePageToApp: async (pageId, accessToken) => {
    const request = {
      method: "POST" /* POST */,
      url: `${facebookLeadsCommon.baseUrl}/${pageId}/subscribed_apps`,
      body: {
        access_token: accessToken,
        subscribed_fields: ["leadgen"]
      }
    };
    await httpClient.sendRequest(request);
  },
  getPageForms: async (pageId, accessToken) => {
    const request = {
      method: "GET" /* GET */,
      url: `${facebookLeadsCommon.baseUrl}/${pageId}/leadgen_forms`,
      queryParams: {
        access_token: accessToken
      }
    };
    const response = await httpClient.sendRequest(request);
    return response.body.data;
  },
  getLeadDetails: async (leadId, accessToken) => {
    const response = await httpClient.sendRequest({
      method: "GET" /* GET */,
      url: `${facebookLeadsCommon.baseUrl}/${leadId}`,
      queryParams: {
        access_token: accessToken,
        fields: "field_data,created_time,ad_id,ad_name,adset_id,adset_name,campaign_id,campaign_name,form_id,platform"
      }
    });
    return response.body;
  },
  loadSampleData: async (formId, accessToken) => {
    const response = await httpClient.sendRequest({
      method: "GET" /* GET */,
      url: `${facebookLeadsCommon.baseUrl}/${formId}/leads`,
      queryParams: {
        access_token: accessToken,
        fields: "field_data,created_time,ad_id,ad_name,adset_id,adset_name,campaign_id,campaign_name,form_id,platform"
      }
    });
    return response.body;
  },
  transformLeadData: (leadData) => {
    return {
      lead_id: leadData.id,
      form_id: leadData.form_id,
      platform: leadData.platform,
      ad_id: leadData.ad_id,
      ad_name: leadData.ad_name,
      adset_id: leadData.adset_id,
      adset_name: leadData.adset_name,
      campaign_id: leadData.campaign_id,
      campaign_name: leadData.campaign_name,
      created_time: leadData.created_time,
      data: leadData.field_data.reduce(
        (acc, field) => ({
          ...acc,
          [field.name]: field.values && field.values.length > 0 ? field.values[0] : null
        }),
        {}
      )
    };
  }
};

// packages/pieces/community/facebook-leads/src/lib/triggers/new-lead.ts
var newLead = createTrigger2({
  auth: facebookLeadsAuth,
  name: "new_lead",
  displayName: "New Lead",
  description: "Triggers when a new lead is created.",
  type: "APP_WEBHOOK" /* APP_WEBHOOK */,
  sampleData: {},
  props: {
    page: facebookLeadsCommon.page,
    form: facebookLeadsCommon.form
  },
  async onEnable(context5) {
    const page = context5.propsValue["page"];
    await facebookLeadsCommon.subscribePageToApp(page.id, page.accessToken);
    context5.app.createListeners({ events: ["lead"], identifierValue: page.id });
  },
  async onDisable() {
  },
  async test(context5) {
    let form = context5.propsValue.form;
    const page = context5.propsValue.page;
    if (form == void 0 || form == "" || form == null) {
      const forms = await facebookLeadsCommon.getPageForms(page.id, page.accessToken);
      form = forms[0].id;
    }
    const response = await facebookLeadsCommon.loadSampleData(form, context5.auth.access_token);
    return response.data.map((lead) => facebookLeadsCommon.transformLeadData(lead));
  },
  //Return new lead
  async run(context5) {
    let leadPings = [];
    const leads = [];
    const form = context5.propsValue.form;
    const payloadBody = context5.payload.body;
    if (form !== void 0 && form !== "" && form !== null) {
      for (const lead of payloadBody.entry) {
        if (form == lead.changes[0].value.form_id) {
          leadPings.push(lead);
        }
      }
    } else {
      leadPings = payloadBody.entry;
    }
    for (const lead of leadPings) {
      const leadData = await facebookLeadsCommon.getLeadDetails(
        lead.changes[0].value.leadgen_id,
        context5.auth.access_token
      );
      const transformLead = facebookLeadsCommon.transformLeadData(leadData);
      leads.push(transformLead);
    }
    return leads;
  }
});

