      required: true,
      defaultValue: ["help"]
    }),
    channels: Property.MultiSelectDropdown({
      auth: slackAuth,
      displayName: "Channels",
      description: "If no channel is selected, the flow will be triggered for commands in all channels",
      required: false,
      refreshers: [],
      async options({ auth }) {
        if (!auth) {
          return {
            disabled: true,
            placeholder: "connect slack account",
            options: []
          };
        }
        const authentication = auth;
        const accessToken = authentication["access_token"];
        const channels = await getChannels(accessToken);
        return {
          disabled: false,
          placeholder: "Select channel",
          options: channels
        };
      }
    }),
    ignoreBots: Property.Checkbox({
      displayName: "Ignore Bot Messages ?",
      required: true,
      defaultValue: true
    })
  },
  type: "APP_WEBHOOK" /* APP_WEBHOOK */,
  sampleData: void 0,
  onEnable: async (context5) => {
    const teamId = context5.auth.data["team_id"] ?? context5.auth.data["team"]["id"];
    context5.app.createListeners({
      events: ["message"],
      identifierValue: teamId
    });
  },
  onDisable: async (context5) => {
  },
  run: async (context5) => {
    const payloadBody = context5.payload.body;
    const channels = context5.propsValue.channels ?? [];
    const commands = context5.propsValue.commands ?? [];
    const user = context5.propsValue.user;
    if (!["channel", "group"].includes(payloadBody.event.channel_type)) {
      return [];
    }
    if (!(channels.length === 0 || channels.includes(payloadBody.event.channel))) {
      return [];
    }
    if (context5.propsValue.ignoreBots && payloadBody.event.bot_id) {
      return [];
    }
    if (user && payloadBody.event.text) {
      const parsedCommand = parseCommand(
        payloadBody.event.text,
        user,
        commands
      );
      if (parsedCommand && commands.includes(parsedCommand.command)) {
        return [
          {
            ...payloadBody.event,
            parsed_command: parsedCommand
          }
        ];
      }
    }
    return [];
  }
});

// packages/pieces/community/slack/src/lib/actions/get-file.ts
var import_web_api16 = require("@slack/web-api");
var getFileAction = createAction2({
  auth: slackAuth,
  name: "get-file",
  displayName: "Get File",
  description: "Return information about a given file ID.",
  props: {
    fileId: Property.ShortText({
      displayName: "File ID",
      required: true,
      description: "You can pass the file ID from the New Message Trigger payload."
    })
  },
  async run(context5) {
    const client = new import_web_api16.WebClient(context5.auth.access_token);
    const fileData = await client.files.info({ file: context5.propsValue.fileId });
    const fileDownloadUrl = fileData.file?.url_private_download;
    if (!fileDownloadUrl) {
      throw new Error("Unable to find the download URL.");
    }
    const response = await httpClient.sendRequest({
      method: "GET" /* GET */,
      url: fileDownloadUrl,
      authentication: {
        type: "BEARER_TOKEN" /* BEARER_TOKEN */,
        token: context5.auth.access_token
      },
      responseType: "arraybuffer"
    });
    return {
      ...fileData.file,
      data: await context5.files.write({
        fileName: fileData.file?.name || `file`,
        data: Buffer.from(response.body)
      })
    };
  }
});

