          identityId: identity.id,
          platformRole: "ADMIN" /* ADMIN */
        },
        order: {
          created: "ASC"
        }
      });
      if (!isNil(user)) {
        const project = await projectService.getUserProjectOrThrow(user.id);
        await platformPlanService(log95).getOrCreateForPlatform(project.platformId);
        if (action === "refund") {
          await platformPlanService(log95).update({
            platformId: project.platformId,
            ...STANDARD_CLOUD_PLAN
