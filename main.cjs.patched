      request.body.flows = migratedFlows;
    }
  }, async (request, reply) => {
    const result = await templateService(app2.log).update({ id: request.params.id, params: request.body });
    return reply.status(import_http_status_codes48.StatusCodes.OK).send(result);
  });
  app2.delete("/:id", DeleteParams, async (request, reply) => {
    const template = await templateService(app2.log).getOneOrThrow({ id: request.params.id });
    if (template.type === "CUSTOM" /* CUSTOM */) {
