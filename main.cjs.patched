    case "INSTALL" /* INSTALL */:
    case "ACTIVATE" /* ACTIVATE */:
    case "DEACTIVATE" /* DEACTIVATE */:
    case "EXPLORE_VIEW" /* EXPLORE_VIEW */:
      return {
