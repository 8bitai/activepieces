        case "WEBHOOK" /* WEBHOOK */: {
          const renewConfiguration = pieceTrigger.renewConfiguration;
          if (renewConfiguration?.strategy === "CRON" /* CRON */) {
            await jobQueue(log95).removeRepeatingJob({
              flowVersionId
            });
          }
          break;
        }
        case "POLLING" /* POLLING */:
          await jobQueue(log95).removeRepeatingJob({
            flowVersionId
          });
          break;
        case "MANUAL" /* MANUAL */:
          break;
      }
    }
  };
};
async function handleAppWebhookTrigger({ engineHelperResponse, flowId, projectId, pieceName }) {
  for (const listener2 of engineHelperResponse.result.listeners) {
