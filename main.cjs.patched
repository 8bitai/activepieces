}
async function getPersonalPlatformIdForIdentity(identityId) {
  const edition6 = system.getEdition();
  if (edition6 === "cloud" /* CLOUD */) {
    const platforms = await platformService.listPlatformsForIdentityWithAtleastProject({ identityId });
    const platform = platforms.find((platform2) => !platformUtils.isCustomerOnDedicatedDomain(platform2));
    return platform?.id ?? null;
  }
  return null;
}

