  props: {
    emojis: Property.Array({
      displayName: "Emojis (E.g fire, smile)",
      description: "Select emojis to trigger on",
      required: false
    }),
    channel: slackChannel(false)
  },
  type: "APP_WEBHOOK" /* APP_WEBHOOK */,
  sampleData: void 0,
  onEnable: async (context5) => {
    const teamId = context5.auth.data["team_id"] ?? context5.auth.data["team"]["id"];
