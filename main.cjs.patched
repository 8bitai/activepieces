      assertNotNullOrUndefined(text, "text");
      assertNotNullOrUndefined(userId2, "userId");
      const postMessage = await slackSendMessage({
        token: token2,
        text: `${context5.propsValue.text}`,
        username: username2,
        profilePicture: profilePicture2,
        conversationId: userId2
      });
      const dmId = postMessage.channel;
      const messageTs = postMessage.ts;
      const approvalLink = context5.generateResumeUrl({
        queryParams: { action: "approve", messageTs }
