var addNoteToConversationAction = createAction2({
  auth: intercomAuth,
  name: "addNoteToConversation",
  displayName: "Add note to conversation",
  description: "Add a note (for other admins) to an existing conversation",
  props: {
    from: commonProps2.admins({ displayName: "From (Admin)", required: true }),
    conversationId: conversationIdProp("Conversation ID", true),
    body: Property.ShortText({
      displayName: "Message Body",
      required: true
    })
  },
  async run(context5) {
    const client = intercomClient(context5.auth);
    const response = await client.conversations.reply({
      conversation_id: context5.propsValue.conversationId,
      body: {
        type: "admin",
        message_type: "note",
        body: context5.propsValue.body,
        admin_id: context5.propsValue.from
      }
    });
    return response;
  }
});

