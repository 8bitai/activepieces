// packages/shared/src/lib/websocket/socket-utils.ts
var emitWithAck = async (socket2, event, data, options) => {
  const timeoutMs = options?.timeoutMs ?? 4e3;
  const retries = options?.retries ?? 3;
  const retryDelayMs = options?.retryDelayMs ?? 2e3;
  for (let attempt = 0; attempt <= retries; attempt++) {
    const result = await tryCatch(async () => {
      if (!socket2 || !socket2.connected) {
        throw new Error("Socket not connected");
      }
      return await socket2.timeout(timeoutMs).emitWithAck(event, data);
    });
    if (result.error) {
      if (attempt < retries) {
        await new Promise((resolve4) => setTimeout(resolve4, retryDelayMs));
      } else {
        throw result.error;
      }
    } else {
      return result.data;
    }
  }
  throw new Error(`Failed to emit event after ${retries} retries`);
};

