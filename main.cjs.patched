    addOrRemoveTagOnContactAction,
    addOrRemoveTagOnCompanyAction,
    addOrRemoveTagOnConversationAction,
    createArticleAction,
    createConversationAction,
    createTicketAction,
    createUserAction,
    createOrUpdateLeadAction,
    createOrUpdateUserAction,
    replyToConversation,
    sendMessageAction,
    updateTicketAction,
