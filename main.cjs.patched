      schemaVersion: LATEST_JOB_DATA_SCHEMA_VERSION,
      projectId,
      flowVersionId,
      flowId,
      triggerType: "PIECE_TRIGGER" /* PIECE */,
      jobType: "EXECUTE_POLLING" /* EXECUTE_POLLING */,
      platformId
