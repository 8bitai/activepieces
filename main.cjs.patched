  }
  return {
    scheduleOptions: void 0
  };
}
async function handlePollingTrigger({ engineHelperResponse, flowId, flowVersionId, projectId, log: log95 }) {
  const pollingFrequencyCronExpression = `*/${system.getNumber("TRIGGER_DEFAULT_POLL_INTERVAL" /* TRIGGER_DEFAULT_POLL_INTERVAL */) ?? 5} * * * *`;
  if (isNil(engineHelperResponse.result.scheduleOptions)) {
    engineHelperResponse.result.scheduleOptions = {
      cronExpression: pollingFrequencyCronExpression,
      timezone: "UTC",
      type: "CRON_EXPRESSION" /* CRON_EXPRESSION */
    };
  }
  const platformId = await projectService.getPlatformId(projectId);
  await jobQueue(log95).add({
    id: flowVersionId,
    type: "repeating" /* REPEATING */,
