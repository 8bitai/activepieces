var flagController = async (app2) => {
  app2.get(
    "/",
    {
      config: {
        security: securityAccess.public()
      },
      logLevel: "silent"
    },
    async (request) => {
      const flags = await flagService.getAll();
      const flagsMap = flags.reduce(
        (map, flag) => ({ ...map, [flag.id]: flag.value }),
        {}
      );
      return flagHooks.get().modify({
        flags: flagsMap,
        request
      });
    }
  );
};

// packages/server/api/src/app/flows/flow/flow-service-side-effects.ts
var flowSideEffects = (log95) => ({
  async preUpdateStatus({
    newStatus,
    flowToUpdate,
    publishedFlowVersion,
    templateId
  }) {
    switch (newStatus) {
      case "ENABLED" /* ENABLED */: {
        await triggerSourceService(log95).enable({
          flowVersion: publishedFlowVersion,
          projectId: flowToUpdate.projectId,
          simulate: false,
          templateId
        });
        break;
      }
      case "DISABLED" /* DISABLED */: {
        await triggerSourceService(log95).disable({
          flowId: publishedFlowVersion.flowId,
          projectId: flowToUpdate.projectId,
          simulate: false,
          ignoreError: false,
          templateId
        });
        break;
      }
    }
  },
  async preDelete({ flowToDelete }) {
    if (flowToDelete.status === "DISABLED" /* DISABLED */ || isNil(flowToDelete.publishedVersionId)) {
      return;
    }
    await triggerSourceService(log95).disable({
      flowId: flowToDelete.id,
      projectId: flowToDelete.projectId,
      simulate: false,
      ignoreError: true
    });
    await sampleDataService(log95).deleteForFlow({
      projectId: flowToDelete.projectId,
      flowId: flowToDelete.id,
      fileType: "SAMPLE_DATA" /* SAMPLE_DATA */
    });
    await sampleDataService(log95).deleteForFlow({
      projectId: flowToDelete.projectId,
      flowId: flowToDelete.id,
      fileType: "SAMPLE_DATA_INPUT" /* SAMPLE_DATA_INPUT */
    });
  }
});

// packages/server/api/src/app/flows/flow/flow.jobs.ts
var flowBackgroundJobs = (log95) => ({
  deleteHandler: async (data) => {
    const { flow, preDeleteDone, dbDeleteDone } = data;
    const job = await systemJobsSchedule(log95).getJob(`delete-flow-${flow.id}`);
    assertNotNullOrUndefined(job, "job is required");
    if (!preDeleteDone) {
      await flowSideEffects(log95).preDelete({
        flowToDelete: flow
      });
      await job.updateData({
        ...data,
        preDeleteDone: true
      });
    }
    if (!dbDeleteDone) {
      await flowRepo().delete({ id: flow.id });
      await job.updateData({
        ...data,
        preDeleteDone: true,
        dbDeleteDone: true
      });
    }
    await flowExecutionCache(log95).invalidate(flow.id);
  },
  updateStatusHandler: async (data) => {
    const { id, projectId, newStatus, preUpdateDone } = data;
    const job = await systemJobsSchedule(log95).getJob(`update-flow-status-${id}`);
    assertNotNullOrUndefined(job, "job");
    const { error } = await tryCatch(async () => {
      const flowToUpdate = await flowService(log95).getOneOrThrow({
        id,
        projectId
      });
      const publishedFlowVersionId = flowToUpdate.publishedVersionId;
      if (flowToUpdate.status !== newStatus) {
        assertNotNullOrUndefined(publishedFlowVersionId, "publishedFlowVersionId is required");
        const publishedFlowVersion = await flowVersionService(log95).getFlowVersionOrThrow({
          flowId: flowToUpdate.id,
          versionId: publishedFlowVersionId
        });
        const templateId = flowToUpdate.templateId ?? void 0;
        if (!preUpdateDone) {
          await flowSideEffects(log95).preUpdateStatus({
            flowToUpdate,
            publishedFlowVersion,
            newStatus,
            templateId
          });
          await job.updateData({
            ...data,
            preUpdateDone: true
          });
        }
        await flowRepo().save({
          ...flowToUpdate,
          status: newStatus,
          operationStatus: "NONE" /* NONE */,
          publishedVersionId: publishedFlowVersion.id
        });
        await flowExecutionCache(log95).invalidate(id);
      }
    });
    if (error) {
      await flowRepo().update(id, {
        operationStatus: "NONE" /* NONE */
      });
    }
    const flow = await flowService(log95).getOnePopulatedOrThrow({
      id,
      projectId
    });
    const response = {
      flow,
      error: isNil(error) || error?.error.code !== "TRIGGER_UPDATE_STATUS" /* TRIGGER_UPDATE_STATUS */ ? void 0 : error?.error
    };
    websocketService.to(projectId).emit("FLOW_STATUS_UPDATED" /* FLOW_STATUS_UPDATED */, response);
    if (!isNil(error)) {
      throw error;
    }
  }
});

// packages/server/api/src/app/flows/flow/human-input/chat-controller.ts
var import_type_provider_typebox21 = require("@fastify/type-provider-typebox");

// packages/server/api/src/app/flows/flow/human-input/human-input.service.ts
var FORMS_PIECE_NAME = "@activepieces/piece-forms";
var FORM_TRIIGGER = "form_submission";
var FILE_TRIGGER = "file_submission";
var SIMPLE_FILE_PROPS = {
  inputs: [
    {
      displayName: "File",
      description: "",
      type: "file" /* FILE */,
      required: true
    }
  ],
  waitForResponse: true
};
var FORMS_TRIGGER_NAMES = [
  FORM_TRIIGGER,
  FILE_TRIGGER
];
function isFormTrigger(flow) {
  if (isNil(flow)) {
    return false;
  }
  const triggerSettings = flow.version.trigger.settings;
  return triggerSettings.pieceName === FORMS_PIECE_NAME && FORMS_TRIGGER_NAMES.includes(triggerSettings.triggerName);
}
var humanInputService = (log95) => ({
  getFormByFlowIdOrThrow: async (flowId, useDraft) => {
    const flow = await getPopulatedFlowById(log95, flowId, useDraft);
    if (!isFormTrigger(flow)) {
      throw new ActivepiecesError({
        code: "FLOW_FORM_NOT_FOUND" /* FLOW_FORM_NOT_FOUND */,
        params: {
          flowId,
          message: "Flow form not found in draft version of flow."
        }
      });
    }
    const pieceVersion = await pieceMetadataService(log95).resolveExactVersion({
      name: FORMS_PIECE_NAME,
      version: flow.version.trigger.settings.pieceVersion,
      platformId: await projectService.getPlatformId(flow.projectId)
    });
    const triggerSettings = flow.version.trigger.settings;
    return {
      id: flow.id,
      title: flow.version.displayName,
      props: triggerSettings.triggerName === FILE_TRIGGER ? SIMPLE_FILE_PROPS : triggerSettings.input,
      projectId: flow.projectId,
      version: pieceVersion
    };
  },
  getChatUIByFlowIdOrThrow: async (flowId, useDraft) => {
    const flow = await getPopulatedFlowById(log95, flowId, useDraft);
    if (!flow || flow.version.trigger.settings.triggerName !== "chat_submission" || flow.version.trigger.settings.pieceName !== FORMS_PIECE_NAME) {
      throw new ActivepiecesError({
        code: "FLOW_FORM_NOT_FOUND" /* FLOW_FORM_NOT_FOUND */,
        params: {
          flowId,
          message: "Flow chat ui not found in draft version of flow."
        }
      });
    }
    const platformId = await projectService.getPlatformId(flow.projectId);
    const platform = await platformService.getOneOrThrow(platformId);
    return {
      id: flow.id,
      title: flow.version.displayName,
      props: flow.version.trigger.settings.input,
      projectId: flow.projectId,
      platformLogoUrl: platform.logoIconUrl,
      platformName: platform.name
    };
  }
});
async function getPopulatedFlowById(log95, id, useDraft) {
  const flow = await flowRepo().findOneBy({ id });
  if (isNil(flow) || isNil(flow.publishedVersionId) && !useDraft) {
    return null;
  }
  const flowVersion = await flowVersionService(log95).getFlowVersionOrThrow({
    flowId: id,
    versionId: useDraft ? void 0 : flow.publishedVersionId
  });
  return {
    ...flow,
    version: flowVersion
  };
}

