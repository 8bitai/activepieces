// packages/server/api/src/app/ee/license-keys/license-keys-controller.ts
var licenseKeysController = async (app2) => {
  app2.get("/:licenseKey", GetLicenseKeyRequest, async (req) => {
    const licenseKey = await licenseKeysService(app2.log).getKey(req.params.licenseKey);
    return licenseKey;
  });
  app2.post("/verify", VerifyLicenseKeyRequest, async (req) => {
    const { platformId, licenseKey } = req.body;
    const key = await licenseKeysService(app2.log).verifyKeyOrReturnNull({
      platformId,
      license: licenseKey
    });
    if (isNil(key)) {
      throw new ActivepiecesError({
        code: "INVALID_LICENSE_KEY" /* INVALID_LICENSE_KEY */,
        params: {
          key: licenseKey
        }
      });
    }
    await licenseKeysService(app2.log).applyLimits(platformId, key);
    return key;
  });
};
var VerifyLicenseKeyRequest = {
  config: {
    security: securityAccess.public()
  },
  schema: {
    body: VerifyLicenseKeyRequestBody
  }
};
