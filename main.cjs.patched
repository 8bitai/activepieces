// packages/server/api/src/app/pieces/piece-sync-service.ts
var import_semver11 = __toESM(require("semver"));
var CLOUD_API_URL = "https://cloud.activepieces.com/api/v1/pieces";
var syncMode = system.get("PIECES_SYNC_MODE" /* PIECES_SYNC_MODE */);
var pieceSyncService = (log95) => ({
  async setup() {
    systemJobHandlers.registerJobHandler("pieces-sync" /* PIECES_SYNC */, async function syncPiecesJobHandler() {
      await pieceSyncService(log95).sync();
    });
    rejectedPromiseHandler(pieceSyncService(log95).sync(), log95);
    await systemJobsSchedule(log95).upsertJob({
      job: {
        name: "pieces-sync" /* PIECES_SYNC */,
        data: {}
      },
      schedule: {
        type: "repeated",
        cron: `${Math.floor(Math.random() * 5)} */1 * * *`
      }
    });
  },
  async sync() {
    if (syncMode !== "OFFICIAL_AUTO" /* OFFICIAL_AUTO */) {
      log95.info("Piece sync service is disabled");
      return;
    }
    try {
      log95.info("Starting piece synchronization");
      const startTime = performance.now();
      const [dbPieces, cloudPieces] = await Promise.all([pieceRepos().find({
        select: {
          name: true,
          version: true,
          pieceType: true
        }
      }), listCloudPieces()]);
      const added = await installNewPieces(cloudPieces, dbPieces, log95);
      const deleted = await deletePiecesIfNotOnCloud(dbPieces, cloudPieces, log95);
      log95.info({
        added,
        deleted,
        durationMs: Math.floor(performance.now() - startTime)
      }, "Piece synchronization completed");
      await localPieceCache(log95).refresh();
    } catch (error) {
      log95.error({ error }, "Error syncing pieces");
    }
  }
});
async function deletePiecesIfNotOnCloud(dbPieces, cloudPieces, log95) {
  const cloudMap = new Map(cloudPieces.map((cloudPiece) => [`${cloudPiece.name}:${cloudPiece.version}`, true]));
  const piecesToDelete = dbPieces.filter((piece) => piece.pieceType === "OFFICIAL" /* OFFICIAL */ && !cloudMap.has(`${piece.name}:${piece.version}`));
  await pieceMetadataService(log95).bulkDelete(piecesToDelete.map((piece) => ({ name: piece.name, version: piece.version })));
  return piecesToDelete.length;
}
async function installNewPieces(cloudPieces, dbPieces, log95) {
  const dbMap = new Map(dbPieces.map((dbPiece) => [`${dbPiece.name}:${dbPiece.version}`, true]));
  const newPiecesToFetch = cloudPieces.filter((piece) => !dbMap.has(`${piece.name}:${piece.version}`));
  const batchSize = 5;
  for (let done = 0; done < newPiecesToFetch.length; done += batchSize) {
    const currentBatch = newPiecesToFetch.slice(done, done + batchSize);
    await Promise.all(currentBatch.map(async (piece) => {
      const url = `${CLOUD_API_URL}/${piece.name}${piece.version ? "?version=" + piece.version : ""}`;
      const response = await fetch(url);
      if (!response.ok) {
        log95.warn({ name: piece.name, version: piece.version, status: response.status }, "Error reading piece metadata");
        return;
      }
      const pieceMetadata = await response.json();
      await pieceMetadataService(log95).create({
        pieceMetadata,
        packageType: pieceMetadata.packageType,
        pieceType: pieceMetadata.pieceType
      });
    }));
  }
  return newPiecesToFetch.length;
}
async function listCloudPieces() {
  const queryParams = new URLSearchParams();
  queryParams.append("edition", system.getEdition());
  queryParams.append("release", await apVersionUtil.getCurrentRelease());
  const response = await fetch(`${CLOUD_API_URL}/registry?${queryParams.toString()}`);
  if (!response.ok) {
    throw new Error(`Failed to fetch cloud pieces: ${response.status}`);
  }
  const pieces = await response.json();
  const piecesByName = groupBy(pieces, (p) => p.name);
  const latest = [];
  const others = [];
  for (const group of Object.values(piecesByName)) {
    const sortedByVersion = sortByVersionDesc(group);
    latest.push(sortedByVersion[0]);
    others.push(...sortedByVersion.slice(1));
  }
  return [...latest, ...others];
}
function sortByVersionDesc(items) {
  return [...items].sort(
    (a, b) => import_semver11.default.rcompare(a.version, b.version)
  );
}

