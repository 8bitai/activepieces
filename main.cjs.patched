      badges.push("first-build");
    }
    if (uniqueActiveFlows.size >= 5) {
      badges.push("on-a-roll");
    }
    if (uniqueActiveFlows.size >= 10) {
      badges.push("automation-addict");
    }
    if (uniqueActiveFlows.size >= 50) {
      badges.push("cant-stop");
    }
