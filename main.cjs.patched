      let timeout;
      if (timeoutRequest) {
        timeout = setTimeout(() => {
          log95.info("[engineWatcher#listen] Timeout reached");
          listeners.delete(requestId);
          resolve4(defaultResponse);
        }, timeoutMs);
      }
      const responseHandler = (flowResponse) => {
        if (timeout) {
          clearTimeout(timeout);
        }
        listeners.delete(requestId);
        log95.info({ requestId }, "[engineWatcher#listen] Response received");
        resolve4(flowResponse.response);
      };
      listeners.set(requestId, responseHandler);
    });
  },
  async shutdown() {
    await pubsub.unsubscribe(`engine-run:sync:${SERVER_ID}`);
  }
});

