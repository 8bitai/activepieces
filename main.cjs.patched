    }
  );
  fastify2.get(
    "/",
    ListFoldersParams,
    async (request) => {
      return flowFolderService(request.log).list({
        projectId: request.projectId,
        cursorRequest: request.query.cursor ?? null,
        limit: request.query.limit ?? DEFAULT_PAGE_SIZE5
      });
    }
  );
  fastify2.delete(
    "/:id",
    DeleteFolderParams,
    async (request, reply) => {
      const folder = await flowFolderService(request.log).getOneOrThrow({
        projectId: request.projectId,
        folderId: request.params.id
      });
      applicationEvents(request.log).sendUserEvent(request, {
        action: "folder.deleted" /* FOLDER_DELETED */,
        data: {
          folder
        }
      });
      await flowFolderService(request.log).delete({
        projectId: request.projectId,
        folderId: request.params.id
      });
      return reply.status(import_http_status_codes36.StatusCodes.OK).send();
    }
  );
};
