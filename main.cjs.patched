// packages/server/api/src/app/flows/flow.module.ts
var flowModule = async (app2) => {
  await app2.register(flowWorkerController, { prefix: "/v1/worker/flows" });
  await app2.register(flowVersionController, { prefix: "/v1/flows" });
  await app2.register(flowController, { prefix: "/v1/flows" });
  await app2.register(sampleDataController, { prefix: "/v1/sample-data" });
  websocketService.addListener("USER" /* USER */, "TEST_FLOW_RUN" /* TEST_FLOW_RUN */, (socket2) => {
    return async (data, principal, projectId) => {
      const flowRun = await flowRunService(app2.log).test({
        projectId,
        flowVersionId: data.flowVersionId,
        triggeredBy: principal.id
      });
      socket2.emit("TEST_FLOW_RUN_STARTED" /* TEST_FLOW_RUN_STARTED */, flowRun);
    };
  });
  websocketService.addListener("USER" /* USER */, "MANUAL_TRIGGER_RUN_STARTED" /* MANUAL_TRIGGER_RUN_STARTED */, (socket2) => {
    return async (data, principal, projectId) => {
      const flowRun = await flowRunService(app2.log).startManualTrigger({
        projectId,
        flowVersionId: data.flowVersionId,
        triggeredBy: principal.id
      });
      socket2.emit("MANUAL_TRIGGER_RUN_STARTED" /* MANUAL_TRIGGER_RUN_STARTED */, flowRun);
    };
  });
  websocketService.addListener("WORKER" /* WORKER */, "EMIT_TEST_STEP_PROGRESS" /* EMIT_TEST_STEP_PROGRESS */, (socket2) => {
    return async (data, _principal, _projectId, callback) => {
      socket2.to(data.projectId).emit("TEST_STEP_PROGRESS" /* TEST_STEP_PROGRESS */, data);
      callback?.();
    };
  });
  websocketService.addListener("WORKER" /* WORKER */, "EMIT_TEST_STEP_FINISHED" /* EMIT_TEST_STEP_FINISHED */, (socket2) => {
    return async (data, _principal, _projectId, callback) => {
      socket2.to(data.projectId).emit("TEST_STEP_FINISHED" /* TEST_STEP_FINISHED */, data);
      callback?.();
    };
  });
  websocketService.addListener("WORKER" /* WORKER */, "UPDATE_RUN_PROGRESS" /* UPDATE_RUN_PROGRESS */, (socket2) => {
    return async (data, _principal, _projectId, callback) => {
      socket2.to(data.flowRun.projectId).emit("UPDATE_RUN_PROGRESS" /* UPDATE_RUN_PROGRESS */, data);
      callback?.();
    };
  });
};

