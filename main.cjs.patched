async function assertUserCanSwitchToPlatform(currentPlatformId, platform) {
  if (isNil(platform)) {
    throw new ActivepiecesError({
      code: "AUTHORIZATION" /* AUTHORIZATION */,
      params: {
        message: "The user is not a member of the platform"
