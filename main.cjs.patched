async function updateSubscription(params) {
  const { extraActiveFlows, stripe, subscription } = params;
  const items = [];
  const currentActiveFlowsItem = subscription.items.data.find((item) => ACTIVE_FLOW_PRICE_ID === item.price.id);
  if (currentActiveFlowsItem?.id) {
    items.push({
      id: currentActiveFlowsItem.id,
      deleted: true
    });
  }
  if (extraActiveFlows > 0) {
    items.push({
      price: ACTIVE_FLOW_PRICE_ID,
      quantity: extraActiveFlows
    });
  }
  await stripe.subscriptions.update(subscription.id, {
    items,
    proration_behavior: "always_invoice"
  });
}
async function updateSubscriptionSchedule(params) {
  const { extraActiveFlows, logger: logger4, scheduleId, stripe, subscription, isFreeDowngrade } = params;
  const { startDate: currentPeriodStart, endDate: currentPeriodEnd } = await stripeHelper(logger4).getSubscriptionCycleDates(subscription);
  const currentPhaseItems = subscription.items.data.map((item) => ({
    price: item.price.id,
    quantity: !isNil(item.quantity) ? item.quantity : void 0
  }));
  const nextPhaseItems = [];
  if (extraActiveFlows > 0) {
    nextPhaseItems.push({
      price: ACTIVE_FLOW_PRICE_ID,
      quantity: extraActiveFlows
    });
  }
  const phases = [
    {
      items: currentPhaseItems,
      start_date: currentPeriodStart,
      end_date: currentPeriodEnd
    }
  ];
  if (!isFreeDowngrade) {
    phases.push({
      items: nextPhaseItems,
      start_date: currentPeriodEnd
    });
  }
  await stripe.subscriptionSchedules.update(scheduleId, {
    phases,
    end_behavior: isFreeDowngrade ? "cancel" : "release"
  });
  logger4.info({
    scheduleId,
    subscriptionId: subscription.id,
    effectiveDate: new Date(currentPeriodEnd * 1e3).toISOString(),
    willCancel: isFreeDowngrade
  }, "Updated subscription schedule for plan change");
}
async function createSubscriptionSchedule(params) {
  const { extraActiveFlows, logger: logger4, stripe, subscription, isFreeDowngrade } = params;
  const schedule = await stripe.subscriptionSchedules.create({
    from_subscription: subscription.id
  });
  await updateSubscriptionSchedule({ stripe, scheduleId: schedule.id, subscription, logger: logger4, extraActiveFlows, isFreeDowngrade });
  return schedule;
}

// packages/server/api/src/app/ee/platform/platform-plan/platform-ai-credits.service.ts
var CREDIT_PER_DOLLAR = 1e3;
var USAGE_CACHE_TTL_SECONDS = 180;
var platformAiCreditsService = (log95) => ({
  async init() {
    systemJobHandlers.registerJobHandler("ai-credit-update-check" /* AI_CREDIT_UPDATE_CHECK */, async ({ apiKeyHash, platformId }) => {
      log95.info("(platformAiCreditsService) AI credit update check");
      try {
        await distributedLock(log95).runExclusive({
          key: `ai_credits_update_${platformId}`,
          timeoutInSeconds: 100,
          fn: async () => {
            const plan = await platformPlanService(log95).getOrCreateForPlatform(platformId);
            await tryResetPlanIncludedCredits(plan, apiKeyHash, log95);
            const autoToppedUp = await tryAutoTopUpPlan(plan, apiKeyHash, log95);
            if (autoToppedUp) {
              await sleep(3e4);
            }
          }
        });
      } catch (e) {
        log95.error(e, "(platformAiCreditsService) AI credit update check failed");
        throw e;
      }
    });
  },
  isEnabled() {
    return flagService.aiCreditsEnabled();
  },
  async getUsage(platformId) {
    if (!this.isEnabled()) {
      return {
        usage: 0,
        limit: 0,
        usageMonthly: 0,
        usageRemaining: 0
      };
    }
    const auth = await aiProviderService(log95).getActivepiecesProviderIfEnriched(platformId);
    if (isNil(auth)) {
      const platformPlan = await platformPlanService(log95).getOrCreateForPlatform(platformId);
      return {
        usage: 0,
        limit: platformPlan.includedAiCredits,
        usageMonthly: 0,
        usageRemaining: platformPlan.includedAiCredits
      };
    }
    assertNotNullOrUndefined(auth.apiKeyHash, "apiKeyHash is required");
    const usage = await getOpenRouterUsageCached(auth.apiKeyHash, log95);
    return {
      usageMonthly: usage.usage_monthly * CREDIT_PER_DOLLAR,
      usageRemaining: usage.limit_remaining * CREDIT_PER_DOLLAR,
      usage: usage.usage * CREDIT_PER_DOLLAR,
      limit: usage.limit * CREDIT_PER_DOLLAR
    };
  },
  async updateAutoTopUp(platformId, request) {
    const plan = await platformPlanService(log95).getOrCreateForPlatform(platformId);
    if (request.state === "disabled" /* DISABLED */) {
      await platformPlanService(log95).update({
        platformId,
        aiCreditsAutoTopUpState: "disabled" /* DISABLED */
      });
      return {};
    }
    await platformPlanService(log95).update({
      platformId,
      aiCreditsAutoTopUpCreditsToAdd: request.creditsToAdd,
      aiCreditsAutoTopUpThreshold: request.minThreshold,
      maxAutoTopUpCreditsMonthly: request.maxMonthlyLimit
    });
    assertNotNullOrUndefined(plan.stripeCustomerId, "Stripe customer id is not set");
    const paymentMethod = await stripeHelper(log95).getPaymentMethod(plan.stripeCustomerId);
    if (!isNil(paymentMethod)) {
      await platformPlanService(log95).update({
        platformId,
        aiCreditsAutoTopUpState: "enabled" /* ENABLED */
      });
      return {};
    }
    const stripeCheckoutUrl = await stripeHelper(log95).createNewAICreditAutoTopUpCheckoutSession({
      platformId,
      customerId: plan.stripeCustomerId
    });
    await platformPlanService(log95).update({
      platformId,
      aiCreditsAutoTopUpState: "disabled" /* DISABLED */
    });
    return { stripeCheckoutUrl };
  },
  async handleAutoTopUpCheckoutSessionCompleted(platformId, paymentMethodId) {
    await platformPlanService(log95).update({
      platformId,
      aiCreditsAutoTopUpState: "enabled" /* ENABLED */
    });
    const plan = await platformPlanService(log95).getOrCreateForPlatform(platformId);
    assertNotNullOrUndefined(plan.stripeCustomerId, "Stripe customer id is not set");
    await stripeHelper(log95).attachPaymentMethodToCustomer(paymentMethodId, plan.stripeCustomerId);
  },
  async initializeStripeAiCreditsPayment(platformId, { aiCredits }) {
    const { stripeCustomerId: customerId } = await platformPlanService(log95).getOrCreateForPlatform(platformId);
    assertNotNullOrUndefined(customerId, "Stripe customer id is not set");
    const amountInUsd = aiCredits / CREDIT_PER_DOLLAR;
    const stripeCheckoutUrl = await stripeHelper(log95).createNewAICreditPaymentCheckoutSession({
      amountInUsd,
      platformId,
      customerId
    });
    return { stripeCheckoutUrl };
  },
  async aiCreditsPaymentSucceeded(platformId, amount, _paymentType) {
    const { apiKeyHash } = await aiProviderService(log95).getOrCreateActivePiecesProviderAuthConfig(platformId);
    const { data: key } = await openRouterApi.getKey({ hash: apiKeyHash });
    await openRouterApi.updateKey({
      hash: apiKeyHash,
      limit: key.limit + amount
    });
  }
});
async function getOpenRouterUsageCached(apiKeyHash, log95) {
  const cacheKey = `openrouter_usage_${apiKeyHash}`;
  const cachedUsage = await distributedStore.get(cacheKey);
  if (!isNil(cachedUsage)) {
