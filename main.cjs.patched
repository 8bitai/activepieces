var folderController = async (fastify2) => {
  fastify2.addHook("preSerialization", entitiesMustBeOwnedByCurrentProject);
  fastify2.post(
    "/",
    CreateFolderParams,
    async (request) => {
      const createdFolder = await flowFolderService(request.log).upsert({
        projectId: request.projectId,
        request: request.body
      });
      applicationEvents(request.log).sendUserEvent(request, {
        action: "folder.created" /* FOLDER_CREATED */,
        data: {
          folder: createdFolder
        }
      });
      return createdFolder;
    }
  );
  fastify2.post(
    "/:id",
    UpdateFolderParams,
    async (request) => {
      const updatedFlow = await flowFolderService(request.log).update({
        projectId: request.projectId,
        folderId: request.params.id,
        request: request.body
      });
      applicationEvents(request.log).sendUserEvent(request, {
        action: "folder.updated" /* FOLDER_UPDATED */,
        data: {
          folder: updatedFlow
