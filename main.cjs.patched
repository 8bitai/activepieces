    const response = await client.tags.list();
    const options = [];
    for (const tag of response.data) {
      options.push({
        value: tag.id,
        label: tag.name
      });
    }
    return {
      disabled: false,
      options
    };
  }
});
var companyIdProp = (displayName, required = true) => Property.Dropdown({
  auth: intercomAuth,
  displayName,
  required,
  refreshers: [],
  options: async ({ auth }) => {
    if (!auth) {
      return {
