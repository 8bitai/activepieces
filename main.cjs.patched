  await app2.register(flowRunLogsController, { prefix: "/v1/flow-runs" });
  systemJobHandlers.registerJobHandler("run-telemetry" /* RUN_TELEMETRY */, async (_job) => {
    if (!telemetry(app2.log).isEnabled()) {
      return;
    }
    app2.log.info({
      name: "run-telemetry" /* RUN_TELEMETRY */
    }, "Run telemetry started");
    const startOfDay = (0, import_dayjs31.default)().startOf("day").toISOString();
    const endOfDay = (0, import_dayjs31.default)().endOf("day").toISOString();
    const projectFlowCounts = await flowRunRepo().createQueryBuilder("flowRun").select('"projectId", "flowId", "environment", COUNT(*) as count').where({
      created: (0, import_typeorm79.Between)(startOfDay, endOfDay)
    }).groupBy('"projectId", "flowId", "environment"').getRawMany();
    for (const { projectId, flowId, environment: environment3, count } of projectFlowCounts) {
      app2.log.info({
        projectId,
        flowId,
        environment: environment3,
        count: parseInt(count, 10)
      }, "Tracking flow run created");
      telemetry(app2.log).trackProject(projectId, {
        name: "run.created" /* FLOW_RUN_CREATED */,
        payload: {
          projectId,
          flowId,
          environment: environment3,
          count: parseInt(count, 10)
        }
      }).catch(
        (e) => app2.log.error(e, "[FlowRunService#Start] telemetry.trackProject")
      );
    }
  });
  await systemJobsSchedule(app2.log).upsertJob({
    job: {
      name: "run-telemetry" /* RUN_TELEMETRY */,
      data: {}
    },
    schedule: {
      type: "repeated",
      cron: "0/50 23 * * *"
    }
  });
  await engineResponseWatcher(app2.log).init();
};

