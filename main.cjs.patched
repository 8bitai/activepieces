  return {
    scheduleOptions: void 0
  };
}
async function handleWebhookTrigger({ flowId, flowVersionId, projectId, pieceTrigger, log: log95 }) {
  const renewConfiguration = pieceTrigger.renewConfiguration;
  switch (renewConfiguration?.strategy) {
    case "CRON" /* CRON */: {
      const platformId = await projectService.getPlatformId(projectId);
      await jobQueue(log95).add({
        id: flowVersionId,
        type: "repeating" /* REPEATING */,
        data: {
          schemaVersion: LATEST_JOB_DATA_SCHEMA_VERSION,
          projectId,
          flowVersionId,
          flowId,
          jobType: "RENEW_WEBHOOK" /* RENEW_WEBHOOK */,
          platformId
