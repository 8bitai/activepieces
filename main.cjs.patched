      })
    })
  ],
  triggers: [
    contactRepliedTrigger,
    leadAddedEmailTrigger,
    leadConvertedToUserTrigger,
    conversationClosedTrigger,
    conversationAssigned,
    conversationSnoozed,
    conversationUnsnoozed,
    newCompanyTrigger,
    newConversationFromUser,
