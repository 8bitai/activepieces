        await updateSubscriptionSchedule({ stripe, scheduleId: currentActiveSchedule.id, subscription, logger: log95, extraActiveFlows, isFreeDowngrade });
        for (let i = 1; i < activeSchedules.length; i++) {
          await stripe.subscriptionSchedules.release(activeSchedules[i].id);
