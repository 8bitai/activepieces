  description: "If checked, adds a mention at the end of the Slack message to indicate which flow sent the notification, with a link to said flow.",
  required: false,
  defaultValue: false
});
var blocks = Property.Json({
  displayName: "Block Kit blocks",
  description: "See https://api.slack.com/block-kit for specs",
  required: false,
  defaultValue: []
});
var userId = Property.Dropdown({
  auth: slackAuth,
  displayName: "User",
  required: true,
  refreshers: [],
  async options({ auth }) {
    if (!auth) {
      return {
        disabled: true,
        placeholder: "connect slack account",
        options: []
      };
    }
    const accessToken = auth.access_token;
    const client = new import_web_api.WebClient(accessToken);
    const users = [];
    for await (const page of client.paginate("users.list", {
      limit: 1e3
      // Only limits page size, not total number of results
    })) {
      const response = page;
      if (response.members) {
        users.push(
          ...response.members.filter((member) => !member.deleted).map((member) => {
            return { label: member.name || "", value: member.id || "" };
          })
        );
      }
    }
    return {
      disabled: false,
      placeholder: "Select User",
      options: users
    };
  }
});
var text = Property.LongText({
  displayName: "Message",
  required: true
});
var actions = Property.Array({
  displayName: "Action Buttons",
  required: true,
  properties: {
    label: Property.ShortText({
      displayName: "Label",
      required: true
    }),
    style: Property.StaticDropdown({
      displayName: "Style",
      required: false,
      defaultValue: null,
      options: {
        options: [
          { label: "Default", value: null },
          { label: "Primary", value: "primary" },
          { label: "Danger", value: "danger" }
        ]
      }
    })
  }
});
async function getChannels(accessToken) {
  const client = new import_web_api.WebClient(accessToken);
  const channels = [];
  const CHANNELS_LIMIT = 2e3;
  let cursor;
  do {
    const response = await client.conversations.list({
      types: "public_channel,private_channel",
      exclude_archived: true,
      limit: 1e3,
      cursor
    });
    if (response.channels) {
      channels.push(
        ...response.channels.map((channel) => {
          return { label: channel.name || "", value: channel.id || "" };
        })
      );
    }
    cursor = response.response_metadata?.next_cursor;
  } while (cursor && channels.length < CHANNELS_LIMIT);
  return channels;
}

// packages/pieces/community/slack/src/lib/common/utils.ts
var import_web_api2 = require("@slack/web-api");
var slackSendMessage = async ({
  text: text2,
  conversationId,
  username: username2,
  profilePicture: profilePicture2,
  iconEmoji: iconEmoji2,
  blocks: blocks2,
  threadTs: threadTs2,
  token: token2,
  file,
  replyBroadcast,
  unfurlLinks
}) => {
  const client = new import_web_api2.WebClient(token2);
  if (file) {
    return await client.files.uploadV2({
      channel_id: conversationId,
      initial_comment: text2,
      thread_ts: threadTs2,
      file_uploads: [
        {
          file: file.data,
          filename: file.filename
        }
      ]
    });
  } else {
    const messageParams = {
      text: text2,
      channel: conversationId,
      username: username2,
      icon_url: profilePicture2,
      icon_emoji: iconEmoji2,
      blocks: blocks2,
      thread_ts: threadTs2
    };
    if (replyBroadcast) {
      messageParams.reply_broadcast = replyBroadcast;
    }
    if (unfurlLinks === false) {
      messageParams.unfurl_links = false;
    }
    return await client.chat.postMessage(messageParams);
  }
};
function processMessageTimestamp(input) {
  const urlRegex = /\/p(\d+)(\d{6})$/;
  const urlMatch = input.match(urlRegex);
  if (urlMatch) {
    const timestamp = `${urlMatch[1]}.${urlMatch[2]}`;
    return timestamp;
  }
  const timestampRegex = /^(\d+)\.(\d{6})$/;
  const timestampMatch = input.match(timestampRegex);
  if (timestampMatch) {
    return input;
  }
  return void 0;
}
function parseCommand(text2, botUserId, validCommands) {
  if (!botUserId) {
    return null;
  }
  const mentionRegex = new RegExp(`<@${botUserId}>\\s+(.+)`, "s");
  const mentionMatch = text2.match(mentionRegex);
  if (!mentionMatch) {
    return null;
  }
  const commandText = mentionMatch[1].trim();
  const parts = commandText.split(/\s+/);
  const command = parts[0].toLowerCase();
  const args = parts.slice(1);
  if (!validCommands.includes(command)) {
    return null;
  }
  return {
    command,
    args
  };
}

// packages/pieces/community/slack/src/lib/common/request-action.ts
var requestAction = async (conversationId, context5) => {
  const { actions: actions2 } = context5.propsValue;
  assertNotNullOrUndefined(actions2, "actions");
  if (!actions2.length) {
    throw new Error(`Must have at least one button action`);
  }
  const actionTextToIds = actions2.map(
    ({ label, style }) => {
      if (!label) {
        throw new Error(`Button text for the action cannot be empty`);
      }
      return {
        label,
        style,
        actionId: encodeURI(label)
      };
    }
  );
  if (context5.executionType === "BEGIN" /* BEGIN */) {
    context5.run.pause({
      pauseMetadata: {
        type: "WEBHOOK" /* WEBHOOK */,
        actions: actionTextToIds.map(
          (action) => action.actionId
        )
      }
    });
    const token2 = context5.auth.access_token;
    const { text: text2, username: username2, profilePicture: profilePicture2 } = context5.propsValue;
    assertNotNullOrUndefined(token2, "token");
    assertNotNullOrUndefined(text2, "text");
    const actionElements = actionTextToIds.map(
      (action) => {
        const actionLink = context5.generateResumeUrl({
          queryParams: { action: action.actionId }
        });
        return {
          type: "button",
          text: {
            type: "plain_text",
            text: action.label
          },
          ...action.style && { style: action.style },
          value: actionLink,
          action_id: action.actionId
        };
      }
    );
    const messageResponse = await slackSendMessage({
      token: token2,
      text: `${context5.propsValue.text}`,
      username: username2,
      profilePicture: profilePicture2,
      threadTs: context5.propsValue.threadTs ? processMessageTimestamp(context5.propsValue.threadTs) : void 0,
      blocks: [
        {
          type: "section",
          text: {
            type: "mrkdwn",
            text: `${context5.propsValue.text}`
          }
        },
        {
          type: "actions",
          block_id: "actions",
          elements: actionElements
        }
      ],
      conversationId
    });
    return {
      action: actionTextToIds.at(0) || "N/A",
      payload: {
        type: "action_blocks",
        user: {
          id: messageResponse.message?.user,
          username: "user.name",
          name: "john.smith",
          team_id: messageResponse.message?.team
        },
        container: {
          type: "message",
          message_ts: messageResponse.ts,
          channel_id: messageResponse.channel,
          is_ephemeral: false
        },
        trigger_id: "trigger_id",
        team: {
          id: messageResponse.message?.team,
          domain: "team_name"
        },
        channel: {
          id: messageResponse.channel,
          name: "#channel"
        },
        message: messageResponse.message,
        state: {},
        actions: [
          {
            action_id: "action_id",
            block_id: "actions",
            value: "resume_url",
            style: "primary",
            type: "button",
            action_ts: "action_ts"
          }
        ]
      }
    };
  } else {
    const payloadQueryParams = context5.resumePayload.queryParams;
    return {
      action: decodeURI(payloadQueryParams.action),
      payload: context5.resumePayload.body
    };
  }
};

